# ============================================
# SistemaDeTickets - Variables de Entorno
# ============================================

# PRODUCCION (rama main)
APP_ENV=production
HTTP_PORT=8006

# Base de Datos - Módulo Ticket (TI / Servicios Generales)
DB_HOST=localhost
DB_PORT=1436
DB_DATABASE=Ticket
DB_USERNAME=sa
DB_DATABASE_COMEDOR_TEST=Comedor
DB_PASSWORD=Your_strong!Passw0rd

# Base de Datos - Módulo Comedor (autenticación de empleados)
DB_DATABASE_COMEDOR=Comedor

# Base de Datos - Módulo Comercial (contactos / lista LBS)
DB_HOST_COMERCIAL=your_comercial_host\COMERCIAL
DB_DATABASE_COMERCIAL=BASENUEVA
DB_USERNAME_COMERCIAL=SA
DB_PASSWORD_COMERCIAL=your_comercial_password

# Base de Datos - Módulo Operaciones (contratos / licitaciones)
DB_HOST_OPERACIONES=your_operaciones_host\SQLEXPRESS
DB_DATABASE_OPERACIONES=Operaciones
DB_USERNAME_OPERACIONES=your_operaciones_username
DB_PASSWORD_OPERACIONES=your_operaciones_password

# TEST (rama dev)
HTTP_PORT_TEST=9006

# Base de Datos Test
DB_HOST_TEST=localhost
DB_PORT_TEST=1436
DB_DATABASE_TEST=Ticket
DB_USERNAME_TEST=sa
DB_PASSWORD_TEST=Your_strong!Passw0rd

# Base de Datos Comercial Test
DB_HOST_COMERCIAL_TEST=your_comercial_host\COMERCIAL
DB_DATABASE_COMERCIAL_TEST=BASENUEVA
DB_USERNAME_COMERCIAL_TEST=SA
DB_PASSWORD_COMERCIAL_TEST=your_comercial_password

# SMTP para notificaciones (Office 365)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=your_email@bacrocorp.com
SMTP_PASSWORD=your_smtp_password

# Correo y nombre del administrador receptor de notificaciones
ADMIN_EMAIL=admin@bacrocorp.com
ADMIN_NAME=Administrador TI BacroCorp

# Zona Horaria
TZ=America/Mexico_City

# URL base de la aplicación (se auto-detecta del HOST si no se especifica)
# Útil para ambientes donde el dominio es fijo
APP_URL=http://desarollo-bacros

# URL del sistema Comedor (servidor externo de licitaciones/contratos)
COMEDOR_URL=http://192.168.100.79

# Snipe-IT - Inventario TI
SNIPE_IT_URL=https://your-snipeit.bacrocorp.com
SNIPE_IT_TEST=your_snipeit_api_token
